/**
 * 将字符串编码为GBK百分号编码
 * @param str 要编码的字符串
 * @returns GBK百分号编码后的字符串
 */
export function encodeToGbk(str: string): string {
  let result = ''
  for (let i = 0; i < str.length; i++) {
    const code = str.charCodeAt(i)

    // ASCII字符直接编码
    if (code >= 0x20 && code <= 0x7E) {
      // 空格编码为%20
      if (code === 0x20) {
        result += '%20'
      } else {
        result += str.charAt(i)
      }
    }
    // 全角ASCII字符 (U+FF01-U+FF5E) -> 0xA3+对应ASCII码-0x20
    else if (code >= 0xFF01 && code <= 0xFF5E) {
      const gbkHigh = 0xA3
      const gbkLow = (code - 0xFF01) + 0xA1
      result += '%' + gbkHigh.toString(16).toUpperCase() + '%' + gbkLow.toString(16).toUpperCase()
    }
    // 全角空格 (U+3000) -> 0xA1A1
    else if (code === 0x3000) {
      result += '%A1%A1'
    }
    // CJK统一汉字 (U+4E00-U+9FFF)
    else if (code >= 0x4E00 && code <= 0x9FFF) {
      const offset = code - 0x4E00
      let row = Math.floor(offset / 94)
      let col = offset % 94
      let gbkHigh: number
      let gbkLow: number

      if (row < 30) {
        gbkHigh = 0xB0 + row
        gbkLow = 0xA1 + col
      } else if (row < 38) {
        gbkHigh = 0xD8 + (row - 30)
        gbkLow = 0xA1 + col
      } else if (row < 54) {
        gbkHigh = 0xE0 + (row - 38)
        gbkLow = 0xA1 + col
      } else if (row < 84) {
        gbkHigh = 0xE8 + (row - 54)
        gbkLow = 0xA1 + col
      } else {
        gbkHigh = 0xF0 + (row - 84)
        gbkLow = 0xA1 + col
      }

      result += '%' + gbkHigh.toString(16).toUpperCase() + '%' + gbkLow.toString(16).toUpperCase()
    }
    // 查找表中的其他字符
    else if (GBK_TABLE[code] !== undefined) {
      const gbkCode = GBK_TABLE[code]
      const high = (gbkCode >> 8) & 0xFF
      const low = gbkCode & 0xFF
      result += '%' + high.toString(16).toUpperCase() + '%' + low.toString(16).toUpperCase()
    }
    // 不在GBK范围内的字符，回退到UTF-8编码
    else {
      result += encodeURIComponent(str.charAt(i))
    }
  }
  return result
}
